{
  "include": ["src/**/*", "__mocks__/**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "~*": ["src/*"] },
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "target": "es2020",
    "lib": ["es2020"],
    "skipLibCheck": true,
    "module": "commonjs",
    "moduleResolution": "node"
  }
}
