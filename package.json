{
  "name": "perfekt",
  "version": "3.0.5",
  "description": "Release and version your packages with perfe(k)t ease!",
  "keywords": [
    "perfekt",
    "perfect",
    "release",
    "version",
    "changelog",
    "manager",
    "cli",
    "semver"
  ],
  "bugs": {
    "url": "https://github.com/lekterable/perfekt/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lekterable/perfekt"
  },
  "license": "MIT",
  "author": "Kornel Dubieniecki (https://kornel.me)",
  "bin": {
    "perfekt": "./dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "ci": "pnpm run validate && pnpm run test:ci && pnpm run build",
    "dev": "tsdown --watch",
    "eslint": "eslint .",
    "format": "prettier 'src/**' --write",
    "format:check": "prettier 'src/**' --check",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "prepare": "pnpm run build && husky",
    "prettier": "prettier 'src/**'",
    "test": "jest",
    "test:ci": "jest --collectCoverage --ci --runInBand",
    "test:coverage": "jest --collectCoverage",
    "test:watch": "jest --watch",
    "types": "tsc --noEmit",
    "validate": "pnpm run format:check && pnpm run lint:check && pnpm run types"
  },
  "dependencies": {
    "commander": "14.0.3",
    "cosmiconfig": "9.0.1",
    "inquirer": "13.3.2",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-mock-process": "2.0.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "tsdown": "0.21.4",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20"
  }
}
